{
  "agents": {
    "defaults": {
      "workspace": ".",
      "model": "responses:gpt-5.4",
      "provider": "auto",
      "runtime": "langgraph",
      "maxTokens": 8192,
      "temperature": 0.1,
      "maxToolIterations": 40,
      "memoryWindow": 100,
      "reasoningEffort": "high",
      "middlewares": [
        {
          "enabled": true,
          "name": "prepend_system_message",
          "classPath": "",
          "options": {
            "text": "[DEEP_MODE_PROTOCOL_V1]\nEvaluate deep-mode entry on every user turn.\nIf any deep-entry condition is met, FIRST action must be enter_deep_mode.\nDeep-entry conditions: explicit plan request; cross-turn dependency; file-memory dependency; long-running/interruptible task; or at least two weak signals (multi-step, multi-tool, phased wording).\nControl intents must call tools before narrative: status->deep_mode_status, pause->deep_mode_pause, continue->deep_mode_resume(replan=true), restart->deep_mode_cancel then enter_deep_mode.\nIf user says \"do not plan\" or \"direct answer\", prefer normal mode unless a strong deep signal exists.\nForbidden: saying \"I will start\" or \"I will continue\" without a tool call.\nWhen must_execute intent is clear and required tool is available, call the tool in this turn.\nIf prior turns already established file placeholders and user asks to continue reading, use these placeholders, or read the file content, call file_vault_read in this turn.\nIf the user asks to open a browser visibly or says they want to see browser actions, call agent_browser with headless=false; use headless=true only for background probing.\nIf a tool call fails, return only one blocking reason plus the next minimal action.\nNever repeat promises without new tool results."
          }
        },
        {
          "enabled": true,
          "name": "tool_call_limit",
          "classPath": "",
          "options": {
            "thread_limit": 60,
            "run_limit": 20,
            "exit_behavior": "continue"
          }
        },
        {
          "enabled": true,
          "name": "tool_retry",
          "classPath": "",
          "options": {
            "max_retries": 1,
            "on_failure": "continue",
            "initial_delay": 0.5,
            "max_delay": 5.0,
            "jitter": true
          }
        },
        {
          "enabled": true,
          "name": "model_retry",
          "classPath": "",
          "options": {
            "max_retries": 1,
            "on_failure": "continue",
            "initial_delay": 0.5,
            "max_delay": 5.0,
            "jitter": true
          }
        },
        {
          "enabled": true,
          "name": "llm_tool_selector",
          "classPath": "",
          "options": {
            "max_tools": 6,
            "forceProviderTypes": [
              "ResponsesProvider"
            ]
          }
        }
      ]
    }
