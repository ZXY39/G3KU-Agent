{
  "agents": {
    "defaults": {
      "workspace": ".",
      "runtime": "langgraph",
      "maxTokens": 8192,
      "temperature": 0.1,
      "maxToolIterations": 40,
      "memoryWindow": 100,
      "reasoningEffort": "high"
    },
    "multiAgent": {
      "orchestratorModelKey": null
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": true
  },
  "models": {
    "catalog": [
      {
        "key": "ceo_primary",
        "providerModel": "responses:gpt-5.4",
        "apiKey": "sk-f053c362909e7bd9285bd593d639dac0f45fde9586a2d84904274a8489fa1bf9",
        "apiBase": "https://cc.sub.258000.sbs/v1/responses",
        "extraHeaders": null,
        "enabled": true,
        "maxTokens": 8192,
        "temperature": 0.1,
        "reasoningEffort": "high",
        "retryOn": [
          "network",
          "429",
          "5xx"
        ],
        "description": "CEO / main agent role profile"
      }
    ],
    "roles": {
      "ceo": [
        "ceo_primary"
      ],
      "execution": [
        "ceo_primary"
      ],
      "inspection": [
        "ceo_primary"
      ]
    }
  },
  "providers": {
    "dashscope": {
      "apiKey": "sk-72f5f64d75eb4c9fbb0c83519e6cc204",
      "apiBase": null,
      "extraHeaders": null
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "heartbeat": {
      "enabled": true,
      "intervalS": 1800
    }
  },
  "tools": {
    "web": {
      "proxy": null,
      "search": {
        "apiKey": "",
        "maxResults": 5
      }
    },
    "exec": {
      "timeout": 60,
      "pathAppend": ""
    },
    "memory": {
      "enabled": true,
      "mode": "dual",
      "backend": "rag",
      "archVersion": "v2",
      "features": {
        "unifiedContext": true,
        "layeredLoading": true,
        "queryPlanner": true,
        "commitPipeline": true,
        "splitStore": true,
        "observability": true
      },
      "checkpointer": {
        "backend": "sqlite",
        "path": "memory/checkpoints.sqlite3"
      },
      "store": {
        "backend": "hybrid",
        "qdrantPath": "memory/qdrant",
        "qdrantCollection": "nanobot_memory_v1",
        "sqlitePath": "memory/memory.db"
      },
      "retrieval": {
        "denseTopK": 24,
        "sparseTopK": 24,
        "fusedTopK": 12,
        "contextTopK": 8,
        "sentenceWindow": 3,
        "maxContextTokens": 1200,
        "defaultLoadLevel": "l1",
        "rerankProviderModel": "dashscope:qwen3-vl-rerank"
      },
      "embedding": {
        "providerModel": "dashscope:qwen3-vl-embedding",
        "batchSize": 32
      },
      "isolation": {
        "mode": "session",
        "namespaceTemplate": [
          "memory",
          "{channel}",
          "{chat_id}"
        ]
      },
      "guard": {
        "mode": "tiered",
        "autoFactConfidence": 0.8
      },
      "compat": {
        "dualWriteLegacyFiles": true
      },
      "commit": {
        "turnTrigger": 20,
        "idleMinutesTrigger": 360
      },
      "cost": {
        "maxIncreasePct": 15
      },
      "bootstrapMode": "new_only",
      "retentionDays": null
    },
    "agentBrowser": {
      "enabled": true,
      "command": "agent-browser",
      "npmCommand": "npm",
      "nodeCommand": "node",
      "requiredMinVersion": "0.16.3",
      "installSpec": "agent-browser@latest",
      "autoInstall": true,
      "autoUpgradeIfBelowMinVersion": true,
      "autoInstallBrowser": true,
      "browserInstallArgs": [
        "install"
      ],
      "defaultHeadless": false,
      "commandTimeoutS": 120,
      "installTimeoutS": 600,
      "sessionEnvKey": "AGENT_BROWSER_SESSION",
      "maxStdoutChars": 120000,
      "maxStderrChars": 120000,
      "extraEnv": {},
      "allowFileAccess": false,
      "defaultColorScheme": null,
      "defaultDownloadPath": ""
    },
    "fileVault": {
      "enabled": true,
      "rootDir": "memory/uploads",
      "indexDbPath": "memory/file_vault.db",
      "maxStorageBytes": 4294967296,
      "thresholdPct": 70,
      "cleanupTargetPct": 55,
      "recentProtectHours": 24
    },
    "pictureWashing": {
      "baseUrl": "",
      "authorization": "",
      "style": "写实",
      "model": "Seedream 4.5",
      "stream": false,
      "timeoutS": 120,
      "autoProbeAuthorization": true,
      "authorizationProbeUrl": "",
      "authorizationProbeTimeoutS": 45,
      "authorizationCookieNames": [
        "sessionid",
        "session_id"
      ]
    },
    "mcpServers": {},
    "restrictToWorkspace": false
  },
  "resources": {
    "enabled": true,
    "skillsDir": "skills",
    "toolsDir": "tools",
    "manifestName": "resource.yaml",
    "reload": {
      "enabled": true,
      "pollIntervalMs": 1000,
      "debounceMs": 400,
      "lazyReloadOnAccess": true,
      "keepLastGoodVersion": true
    },
    "locks": {
      "lockDir": ".g3ku/resource-locks",
      "logicalDeleteGuard": true,
      "windowsFsLock": true
    },
    "statePath": ".g3ku/resources.state.json"
  },
  "orgGraph": {
    "enabled": true,
    "projectStorePath": ".g3ku/org-graph/projects.sqlite3",
    "checkpointStorePath": ".g3ku/org-graph/checkpoints.sqlite3",
    "taskMonitorStorePath": ".g3ku/org-graph/task-monitor.sqlite3",
    "artifactDir": ".g3ku/org-graph/artifacts",
    "defaultMaxDepth": 1,
    "hardMaxDepth": 4,
    "maxParallelUnitsTotal": -1,
    "maxActiveProjectsPerSession": 32,
    "projectNoticeRetention": 200,
    "eventReplayLimit": 1000,
    "governance": {
      "enabled": true,
      "governanceStorePath": ".g3ku/org-graph/governance.sqlite3"
    }
  }
}
