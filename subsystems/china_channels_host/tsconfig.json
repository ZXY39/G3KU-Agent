{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": false,
    "outDir": "dist",
    "rootDir": "src",
    "strict": false,
    "noCheck": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@openclaw-china/shared": ["./src/vendor/shared/index.ts"]
    }
  },
  "include": [
    "src/*.ts",
    "src/qqbot/channel.ts",
    "src/dingtalk/channel.ts",
    "src/wecom/channel.ts",
    "src/wecom/monitor.ts",
    "src/wecom-app/channel.ts",
    "src/wecom-app/monitor.ts",
    "src/wecom-kf/channel.ts",
    "src/wecom-kf/webhook.ts",
    "src/wechat-mp/channel.ts",
    "src/wechat-mp/webhook.ts",
    "src/feishu-china/channel.ts",
    "src/vendor/**/*.ts"
  ],
  "exclude": ["src/**/*.test.ts"]
}
